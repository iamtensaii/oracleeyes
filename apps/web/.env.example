# =============================================================================
# OracleEyes — apps/web/.env   (local: npm run dev)
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for Assistant — local OpenAI-compatible LLM
# -----------------------------------------------------------------------------

LOCAL_LLM_BASE_URL=http://localhost:12434/engines/llama.cpp/v1
LOCAL_LLM_MODEL=docker.io/ai/gemma4:latest
# LOCAL_LLM_API_KEY=

# Browser calls ML here (host port when ML runs in Docker on 8000)
NEXT_PUBLIC_ML_API_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# ADVANCED — optional
# -----------------------------------------------------------------------------

# Market OHLC proxy (/api/market/ohlc) — Alpha Vantage (server-only; free tier ~5 calls/min)
# https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=

# Optional: TradingAgents thin bridge (POST /api/research/tradingagents-memo)
# TRADINGAGENTS_REPO=/abs/path/to/TradingAgents
# TRADINGAGENTS_PYTHON=python3
# TRADINGAGENTS_BRIDGE_TIMEOUT_MS=480000

# Optional — Assistant web_search tool (Google Custom Search JSON API)
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Agent memory (Postgres). Empty = chat works, shorter memory.
DATABASE_URL=postgresql://oracleeyes:oracleeyes@127.0.0.1:5432/oracleeyes

# Next.js server routes → ML (Docker sets this inside container)
# ML_API_URL=http://127.0.0.1:8000
