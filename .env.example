# =============================================================================
# OracleEyes — Docker Compose (same folder as docker-compose.yml)
#   cp .env.example .env
# =============================================================================
#
# The `web` service also loads apps/web/.env (if present). DATABASE_URL / ML_API_URL
# from those files are overridden in compose so in-container Postgres + ml-api still work.
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for Assistant — local OpenAI-compatible LLM (vLLM, Ollama shim, llama.cpp server, etc.)
# -----------------------------------------------------------------------------

# On the Docker host (shell on the same machine as the engine), if the server listens on localhost:
# LOCAL_LLM_BASE_URL=http://localhost:12434/engines/llama.cpp/v1
# From the `web` container when the LLM is bound to the host (compose maps host.docker.internal → gateway):
# LOCAL_LLM_BASE_URL=http://host.docker.internal:12434/engines/llama.cpp/v1
# (compose sets this default when LOCAL_LLM_BASE_URL is empty; override host/port/path as needed)
LOCAL_LLM_BASE_URL=

# Must match a model id your server exposes (example value below):
LOCAL_LLM_MODEL=docker.io/ai/gemma4:latest

# Optional bearer if your local server requires it:
# LOCAL_LLM_API_KEY=

# -----------------------------------------------------------------------------
# ADVANCED — optional
# -----------------------------------------------------------------------------

# Chart “Load from API” (Next route /api/market/ohlc; Alpha Vantage server-only key)
# ALPHA_VANTAGE_API_KEY=

# Optional Assistant web search (Google Custom Search JSON API)
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Rebuild the `web` image if you change this (browser → ML URL baked at build)
# NEXT_PUBLIC_ML_API_URL=http://localhost:8000
